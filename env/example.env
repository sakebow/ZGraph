# ZGraph example environment file
# Copy this file to dev.env / test.env / prod.env and adjust as needed.
# Empty values mean the variable has no built-in default and must be configured.

# ============================================================
# LLM / provider
# ============================================================
# 当前支持三个 provider: deepseek / minimax / kimi
# ZGRAPH_PROVIDERS 为启用的 provider 列表（逗号分隔、小写）
ZGRAPH_PROVIDERS="deepseek,kimi,minimax"
# ZGRAPH_DEFAULT_PROVIDER 决定运行时使用哪一个；缺省时取 ZGRAPH_PROVIDERS 字典序首个
ZGRAPH_DEFAULT_PROVIDER="deepseek"

DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL=""
DEEPSEEK_BASE_URL=""

KIMI_API_KEY=""
KIMI_MODEL=""
KIMI_BASE_URL=""

MINIMAX_API_KEY=""
MINIMAX_MODEL=""
MINIMAX_BASE_URL=""

# --- 单 provider（兼容旧配置）：未设置 ZGRAPH_PROVIDERS 时生效 ---
BASE_URL=""
APIKEY=""
API_KEY=""
MODEL_NAME=""
LLM_MODEL_NAME="gpt-4o-mini"
LLM_PROVIDER="openai"
LLM_TIMEOUT="120"
LLM_TEMPERATURE=""
LLM_TOP_P=""
LLM_MAX_TOKENS=""
LLM_REASONING_EFFORT=""
STRUCTURED_OUTPUT="false"

# ============================================================
# Runtime
# ============================================================
MAX_ROUNDS="50"
ZGRAPH_STREAM="true"
SYSTEM_PROMPT=""
ZGRAPH_OFFLINE="false"
ZGRAPH_RUN_TTL_SECONDS="86400"
ZGRAPH_ALLOW_BASH="false"
ZGRAPH_AUTO_APPROVE_INTERRUPTS="false"

# ============================================================
# Server / workspace
# ============================================================
HOST="127.0.0.1"
PORT="8001"
ZGRAPH_HOME="./.zgraph"
ZGRAPH_DATA_DIR=""
ZGRAPH_LAYER_CONFIG="./zgraph.config.default.yaml"
WHITELIST=""

# ============================================================
# Capability retrieval
# ============================================================
ZGRAPH_TOKENIZER_STRATEGY="word"
RERANK_MODEL_NAME=""
RERANK_BASE_URL=""
RERANK_API_KEY=""
RERANK_TIMEOUT="30"
RERANK_DOCUMENT_CHAR_LIMIT="1024"
RERANK_BATCH_SIZE="4"
SKILL_SEARCH="true"
SKILL_TOP_K="4"
SKILL_MIN_SCORE="0.18"
SKILL_CONTEXT_CHAR_LIMIT="1200"
TOOL_TOP_K="4"
TOOL_MIN_SCORE="0.18"

# ============================================================
# Memory / logging
# ============================================================
MEMORY_SUMMARY_MAX_TOKENS="256"
MEMORY_SUMMARY_TEMPERATURE="0.2"
ZGRAPH_LOG_LEVEL="INFO"
ZGRAPH_LOG_ENABLED="true"

# ============================================================
# Domain-specific credentials used by skills (e.g. exam-plan)
# ============================================================
ZBZN_BASE_URL=""
ZBZN_API_KEY=""
