# ZGraph example environment file
# Copy this file to dev.env / test.env / prod.env and adjust as needed.
# Empty values mean the variable has no built-in default and must be configured.

# ============================================================
# LLM / provider
# ============================================================
BASE_URL=""						                    # 必要
APIKEY=""						                    # 必要
API_KEY=""						                    # 非必要
MODEL_NAME=""						                # 非必要
LLM_MODEL_NAME="gpt-4o-mini"				        # 非必要
LLM_PROVIDER="openai"					            # 非必要
LLM_TIMEOUT="120"					                # 非必要
LLM_TEMPERATURE=""					                # 非必要
LLM_TOP_P=""						                # 非必要
LLM_MAX_TOKENS=""					                # 非必要
LLM_REASONING_EFFORT=""					            # 非必要
STRUCTURED_OUTPUT="false"				            # 非必要

# ============================================================
# Runtime
# ============================================================
MAX_ROUNDS="50"						                # 非必要
ZGRAPH_STREAM="true"					            # 非必要
SYSTEM_PROMPT=""					                # 非必要
ZGRAPH_OFFLINE="false"					            # 非必要
ZGRAPH_RUN_TTL_SECONDS="86400"				        # 非必要
ZGRAPH_ALLOW_BASH="false"				            # 非必要
ZGRAPH_AUTO_APPROVE_INTERRUPTS="false"			    # 非必要

# ============================================================
# Server / workspace
# ============================================================
HOST="127.0.0.1"					                # 非必要
PORT="8001"						                    # 非必要
ZGRAPH_HOME="./.zgraph"					            # 非必要
ZGRAPH_DATA_DIR=""					                # 非必要
ZGRAPH_LAYER_CONFIG="./zgraph.config.default.yaml"	# 非必要
WHITELIST=""						                # 非必要

# ============================================================
# Capability retrieval
# ============================================================
ZGRAPH_TOKENIZER_STRATEGY="word"			        # 非必要
RERANK_MODEL_NAME=""					            # 非必要
RERANK_BASE_URL=""					                # 非必要
RERANK_API_KEY=""					                # 非必要
RERANK_TIMEOUT="30"					                # 非必要
RERANK_DOCUMENT_CHAR_LIMIT="1024"			        # 非必要
RERANK_BATCH_SIZE="4"					            # 非必要
SKILL_SEARCH="true"					                # 非必要
SKILL_TOP_K="4"						                # 非必要
SKILL_MIN_SCORE="0.18"					            # 非必要
SKILL_CONTEXT_CHAR_LIMIT="1200"				        # 非必要
TOOL_TOP_K="4"						                # 非必要
TOOL_MIN_SCORE="0.18"					            # 非必要

# ============================================================
# Memory / logging
# ============================================================
MEMORY_SUMMARY_MAX_TOKENS="256"				        # 非必要
MEMORY_SUMMARY_TEMPERATURE="0.2"			        # 非必要
ZGRAPH_LOG_LEVEL="INFO"					            # 非必要
ZGRAPH_LOG_ENABLED="true"				            # 非必要

# ============================================================
# Domain-specific credentials used by skills (e.g. exam-plan)
# ============================================================
ZBZN_BASE_URL=""					                # 非必要
ZBZN_API_KEY=""						                # 非必要
